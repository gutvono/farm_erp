# =============================================================================
# Variáveis de produção — copie para .env.prod para testes locais
# No Railway, configure cada variável no dashboard do serviço correspondente.
# =============================================================================

# ── Backend ──────────────────────────────────────────────────────────────────

# Railway injeta automaticamente ao linkar um serviço Postgres ao backend.
# Para testes locais com docker-compose.prod.yml, use o valor abaixo.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/coffee_farm_erp

# Chave secreta para sessões — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# URLs permitidas pelo CORS — no Railway, informe a URL pública do frontend.
# Separe múltiplas origens por vírgula, sem espaços.
# Ex: ALLOWED_ORIGINS=https://meuapp.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────

# URL pública do backend. No Railway, use a URL gerada para o serviço backend.
# Esta variável é embutida no bundle no momento do build (NEXT_PUBLIC_).
# Ex: NEXT_PUBLIC_API_URL=https://backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
