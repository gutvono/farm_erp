# =============================================================================
# Coffee Farm ERP - .gitignore
# =============================================================================

# =============================================================================
# SEGREDOS E CONFIGURAÇÕES LOCAIS
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# =============================================================================
# PYTHON / BACKEND
# =============================================================================

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribuição / build
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Poetry
# poetry.toml contém configuração in-project (não sensível) — mantido no repo
# poetry.lock deve ser commitado para reprodutibilidade

# Pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# Mypy / Ruff / linters
.mypy_cache/
.ruff_cache/

# Uploads gerados em runtime
backend/uploads/*
!backend/uploads/.gitkeep

# =============================================================================
# NODE / FRONTEND
# =============================================================================

# Dependências
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build Next.js
frontend/.next/
frontend/out/

# Cache
.npm
.eslintcache

# =============================================================================
# SISTEMA OPERACIONAL
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# IDEs E EDITORES
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
.#*
\#*#

# =============================================================================
# MISCELÂNEOS
# =============================================================================

# Arquivos temporários
*.tmp
*.temp
*.bak

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
